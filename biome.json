{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "files": { "includes": ["src/**", "tests/**", "*.ts", "!tests/fixtures", "!src/vendor"] },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 160 },
  "javascript": { "formatter": { "quoteStyle": "double", "semicolons": "always" } },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "suspicious": { "noExplicitAny": "off", "noThenProperty": "off", "useIterableCallbackReturn": "off", "noAssignInExpressions": "off" },
      "style": { "noNonNullAssertion": "off", "useTemplate": "off" }
    }
  },
  "assist": { "enabled": false }
}
